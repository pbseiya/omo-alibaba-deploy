# OMO (Oh My OpenAgent) Configuration Environment Variables
# Copy this file to .env and fill in your actual values
#
# Usage:
#   Linux/macOS: source .env
#   Windows:     Get-Content .env | ForEach-Object { $_.Split('=',2) | Set-Item -Force }
#
# Or add to your shell profile (~/.bashrc, ~/.zshrc, $PROFILE)

# ============================================================
# LiteLLM Proxy Gateway (Recommended)
# ============================================================
# Base URL: https://litellm-proxy-gateway.pbseiyacpro7.workers.dev/v1
# Get your API key from LiteLLM proxy admin dashboard
#
# LITELLM_API_KEY=sk-hd_YOUR_LITELLM_KEY_HERE

# ============================================================
# Alibaba Coding Plan API Keys (3 keys for rotation - fallback)
# ============================================================
# Base URL: https://coding-intl.dashscope.aliyuncs.com/v1
# Get your keys from: https://bailian.console.aliyun.com/
#
# Primary API key (required) - used by 'acp' provider
ALIBABA_API_KEY=sk-sp-YOUR_PRIMARY_KEY_HERE

# Spare API key (required) - used by 'acp-spare' provider, fallback when primary exhausted
ALIBABA_API_KEY_SPARE=sk-sp-YOUR_SPARE_KEY_HERE

# Last resort API key (required) - used by 'acp-last' provider, final fallback
ALIBABA_API_KEY_LAST=sk-sp-YOUR_LAST_KEY_HERE

# ============================================================
# Tavily API Key (for web search MCP)
# ============================================================
# Get your key from: https://tavily.com/
TAVILY_API_KEY=tvly-YOUR_TAVILY_KEY_HERE

# ============================================================
# Model Assignments (optimized for Alibaba Coding Plan)
# ============================================================
# Agent → Model mapping (based on benchmarks):
#   sisyphus, prometheus, oracle, momus, plan → qwen3.7-plus (hardest tasks)
#   hephaestus, build, multimodal-looker, OpenCode-Builder → kimi-k2.5 (coding + vision)
#   metis → qwen3.6-plus (consultant)
#   atlas → qwen3.5-plus (context manager)
#   explore, librarian → qwen3-coder-next (fast code search)
#   sisyphus-junior → glm-4.7 (light tasks)
#
# Provider priority:
#   litellm (LiteLLM Proxy Gateway) → acp → acp-spare → acp-last
