{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "model_fallback": true,
  "agents": {
    "sisyphus": {
      "model": "litellm/qwen3.7-plus"
    },
    "hephaestus": {
      "model": "litellm/kimi-k2.5"
    },
    "prometheus": {
      "model": "litellm/qwen3.7-plus"
    },
    "oracle": {
      "model": "litellm/qwen3.7-plus"
    },
    "metis": {
      "model": "litellm/qwen3.6-plus"
    },
    "momus": {
      "model": "litellm/qwen3.7-plus"
    },
    "atlas": {
      "model": "litellm/qwen3.5-plus"
    },
    "explore": {
      "model": "litellm/qwen3-coder-next"
    },
    "librarian": {
      "model": "litellm/qwen3-coder-next"
    },
    "multimodal-looker": {
      "model": "litellm/kimi-k2.5"
    },
    "sisyphus-junior": {
      "model": "litellm/glm-4.7"
    },
    "build": {
      "model": "litellm/kimi-k2.5"
    },
    "plan": {
      "model": "litellm/qwen3.7-plus"
    },
    "OpenCode-Builder": {
      "model": "litellm/kimi-k2.5"
    }
  },
  "team_mode": {
    "enabled": true,
    "max_parallel_members": 4,
    "max_members": 8,
    "tmux_visualization": true
  },
  "tmux": {
    "enabled": true,
    "layout": "main-vertical",
    "main_pane_size": 60
  },
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [
      400,
      429,
      503,
      529
    ],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 60,
    "timeout_seconds": 30,
    "notify_on_fallback": true
  }
}